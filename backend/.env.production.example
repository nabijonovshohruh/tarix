# Production environment reference for the backend.
#
# Where this goes depends on how you deploy:
# - Railway / Render / most PaaS: don't upload this file — paste each
#   key/value into the platform's dashboard "Environment Variables" screen.
# - VPS with Docker Compose: copy this to `.env` in the repo root (same file
#   docker-compose.yml already reads) and fill in real values.
#
# The frontend needs NO env file of its own — it's a fully static build
# (fetches `/api/*` as a relative path) and is served from this same
# backend process in production (see app.ts / Dockerfile). There is no
# frontend/.env.production to create.

# --- Database ---
# Managed Postgres connection string from your host (Railway/Render provision
# one automatically and expose it as DATABASE_URL already, in which case you
# don't need to set this yourself — check their dashboard). For a VPS running
# docker-compose.yml, this is filled in automatically from POSTGRES_* below.
DATABASE_URL="postgresql://tarix:REPLACE_ME@postgres:5432/tarix?schema=public"
POSTGRES_USER=tarix
POSTGRES_PASSWORD=REPLACE_ME_WITH_A_STRONG_PASSWORD
POSTGRES_DB=tarix

# --- Telegram Bot ---
# From @BotFather (/mybots -> your bot -> API Token). Treat as a secret.
BOT_TOKEN=

# Comma-separated numeric Telegram user IDs to force-promote to admin on their
# next request (bootstrap only — never downgrades an already-promoted admin,
# and never overrides an admin who's been demoted back down in the DB).
# Get your numeric ID from @userinfobot.
ADMIN_TELEGRAM_IDS=

# Public HTTPS URL of the deployed Mini App (your Railway/Render domain or
# your own domain). Used by the bot to build the /start web_app button.
WEBAPP_URL=https://your-app.example.com

# --- Server ---
NODE_ENV=production
# Most PaaS platforms (Railway/Render) inject PORT automatically — leave this
# as-is unless your platform tells you to use a specific value.
PORT=3000

# Must be false/unset in production. Also structurally disabled by NODE_ENV
# in code regardless of this value — see backend/src/config/env.ts.
ALLOW_DEV_AUTH=false

# Not used in production (frontend is same-origin, see note above) — only
# read when NODE_ENV !== production. Safe to leave unset.
FRONTEND_ORIGIN=

# --- Production-only (webhook mode) ---
# Same public HTTPS URL as WEBAPP_URL (or its API subdomain, if you split
# them). The bot registers its webhook at `${WEBHOOK_URL}/bot/webhook`
# automatically on startup — no manual setWebhook call needed.
WEBHOOK_URL=https://your-app.example.com
