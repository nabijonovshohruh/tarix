generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// GRADE_6 was formerly QADIMGI_DUNYO (renamed in-place via a migration that
// preserves all existing Test rows — see migrations/20260715_period_grades).
// ORTA_ASRLAR/YANGI_DAVR/ENG_YANGI_DAVR are legacy values no longer used by
// the app (verified zero Test rows referenced them at migration time);
// Postgres can't drop enum values without a full type rebuild, so they're
// left in place inert rather than referenced anywhere in app code.
enum Period {
  GRADE_6
  ORTA_ASRLAR
  YANGI_DAVR
  ENG_YANGI_DAVR
  GRADE_7_JAHON
  GRADE_7_UZBEKISTON
  GRADE_8_JAHON
  GRADE_8_UZBEKISTON
  GRADE_9_JAHON
  GRADE_9_UZBEKISTON
  GRADE_10_JAHON
  GRADE_10_UZBEKISTON
  GRADE_11_JAHON
  GRADE_11_UZBEKISTON
}

enum CorrectOption {
  A
  B
  C
  D
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum ExamStatus {
  PASSED
  FAILED
}

enum Role {
  GUEST
  STUDENT
  ADMIN
}

// Legacy field, no longer required/used by the app now that every Period
// value already encodes its own grade+subject split (see Period enum above).
// Left in place unused rather than dropped — every existing Test row already
// has subCategory = null, so keeping the column is zero-risk.
enum SubCategory {
  UZBEKISTON
  JAHON
}

// role is a real, admin-manageable column (promote/demote + assign group via
// PATCH /students/:id). ADMIN_TELEGRAM_IDS remains a "break-glass" bootstrap:
// on every request, telegramAuth.ts force-upgrades (never downgrades) a
// matching account to ADMIN, so env-configured teachers can never be locked
// out even if their DB role is somehow wrong.
model Student {
  id                BigInt   @id @default(autoincrement())
  telegramId        BigInt   @unique
  fullName          String
  // False until the bot's mandatory name-registration conversation completes
  // (see bot/bot.ts) — every other bot command and the entire Mini App are
  // locked while this is false. Independent of role: a guest can be fully
  // registered (real name on file) while still awaiting an admin's promotion
  // to STUDENT.
  isRegistered      Boolean  @default(false)
  // True while the bot is waiting for the student's reply to /editname —
  // same one-field-as-conversation-state pattern as isRegistered above.
  awaitingNameEdit  Boolean  @default(false)
  // True while the bot is waiting for an admin's /sendall broadcast content.
  // Only ever set on rows env.adminTelegramIds recognizes as an admin.
  awaitingBroadcast Boolean  @default(false)
  username          String?
  role              Role     @default(GUEST)
  groupName         String?
  createdAt         DateTime @default(now())

  testResults       TestResult[]
  attendanceRecords AttendanceRecord[]
  examResults       ExamResult[]
}

model Test {
  id          BigInt       @id @default(autoincrement())
  title       String
  period      Period
  subCategory SubCategory?
  isPublished Boolean      @default(false)
  // Free-preview topics: guests may view/take these even though every other
  // topic (and all exams) require student/admin. New topics default closed;
  // the teacher opts individual topics into the free tier via the admin
  // toggle (PUT /tests/:id { isFree }).
  isFree      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  questions Question[]
  results   TestResult[]
}

model Question {
  id            BigInt        @id @default(autoincrement())
  testId        BigInt
  test          Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer CorrectOption
  explanation   String?
  order         Int           @default(0)

  @@index([testId])
}

model TestResult {
  id         BigInt       @id @default(autoincrement())
  studentId  BigInt
  student    Student      @relation(fields: [studentId], references: [id])
  testId     BigInt
  test       Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  score      Int
  percentage Float
  createdAt  DateTime     @default(now())

  answers    TestAnswer[]

  @@index([studentId])
  @@index([testId])
}

// One row per question per submission, fully denormalized (question text/
// options/correctAnswer/explanation copied at submission time). questionId is
// an unenforced reference (no @relation) so editing/deleting a Question later
// never corrupts historical review data. Rows created before this model
// existed have no TestAnswer rows — review is "unavailable" for those, not
// backfilled (the original selections were never captured).
model TestAnswer {
  id             BigInt         @id @default(autoincrement())
  resultId       BigInt
  result         TestResult     @relation(fields: [resultId], references: [id], onDelete: Cascade)
  questionId     BigInt?
  order          Int
  questionText   String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctAnswer  CorrectOption
  explanation    String?
  selectedOption CorrectOption?
  isCorrect      Boolean

  @@index([resultId])
}

model AttendanceSession {
  id        BigInt        @id @default(autoincrement())
  title     String
  startTime DateTime      @default(now())
  endTime   DateTime
  status    SessionStatus @default(ACTIVE)
  createdAt DateTime      @default(now())

  records AttendanceRecord[]
}

model AttendanceRecord {
  id        BigInt            @id @default(autoincrement())
  studentId BigInt
  student   Student           @relation(fields: [studentId], references: [id])
  sessionId BigInt
  session   AttendanceSession @relation(fields: [sessionId], references: [id])
  createdAt DateTime          @default(now())

  @@unique([studentId, sessionId])
  @@index([sessionId])
}

model Exam {
  id              BigInt    @id @default(autoincrement())
  title           String
  isPublished     Boolean   @default(false)
  durationMinutes Int?
  // Optional scheduling window (separate from durationMinutes, which is the
  // per-attempt countdown once a student starts): when set, the exam can
  // only be opened/submitted between startTime and endTime. NULL means no
  // restriction — existing exams are unaffected. Enforced in
  // exams.controller.ts (getExam/submitExam), bypassed entirely for admins.
  startTime       DateTime?
  endTime         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  questions ExamQuestion[]
  results   ExamResult[]
}

model ExamQuestion {
  id            BigInt        @id @default(autoincrement())
  examId        BigInt
  exam          Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionText  String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer CorrectOption
  explanation   String?
  order         Int           @default(0)

  @@index([examId])
}

model ExamResult {
  id             BigInt       @id @default(autoincrement())
  studentId      BigInt
  student        Student      @relation(fields: [studentId], references: [id])
  examId         BigInt
  exam           Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  score          Int
  totalQuestions Int
  percentage     Float
  status         ExamStatus
  createdAt      DateTime     @default(now())

  answers        ExamAnswer[]

  // A student may attempt a given exam exactly once — enforced here at the
  // DB level (not just app-level), same pattern as AttendanceRecord's
  // one-mark-per-session constraint.
  @@unique([studentId, examId])
  @@index([examId])
}

// Mirrors TestAnswer for exams — see TestAnswer doc comment above.
model ExamAnswer {
  id             BigInt         @id @default(autoincrement())
  resultId       BigInt
  result         ExamResult     @relation(fields: [resultId], references: [id], onDelete: Cascade)
  questionId     BigInt?
  order          Int
  questionText   String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctAnswer  CorrectOption
  explanation    String?
  selectedOption CorrectOption?
  isCorrect      Boolean

  @@index([resultId])
}

// Each value fully determines its top-level section too (no separate
// "category" column needed): DARSLIKLAR/MUHIM_QOLLANMALAR belong to
// "Qo'llanmalar", UMUMIY_SERTIFIKAT/MAVZULASHGAN_SERTIFIKAT to "Milliy
// Sertifikat Testlari" — the category grouping is a pure UI concern (see
// frontend/src/api/types.ts).
enum MaterialSection {
  DARSLIKLAR
  MUHIM_QOLLANMALAR
  UMUMIY_SERTIFIKAT
  MAVZULASHGAN_SERTIFIKAT
}

// Only meaningful for MAVZULASHGAN_SERTIFIKAT, which the student further
// narrows down by grade/subject before seeing a flat material list — every
// other section keeps its original flat list unchanged. Enforced at the app
// layer in materials.controller.ts (required when section is
// MAVZULASHGAN_SERTIFIKAT, forced to null otherwise), not a DB constraint,
// mirroring Test.subCategory's relationship with Period.
enum MaterialSubSection {
  GRADE_6
  GRADE_7_JAHON
  GRADE_7_UZBEKISTON
  GRADE_8_JAHON
  GRADE_8_UZBEKISTON
  GRADE_9_JAHON
  GRADE_9_UZBEKISTON
  GRADE_10_JAHON
  GRADE_10_UZBEKISTON
  GRADE_11_JAHON
  GRADE_11_UZBEKISTON
}

// Files are never stored on our server — fileId is a Telegram file_id,
// obtained by relaying the admin's upload through the bot (sendDocument to
// the uploading admin's own chat) and capturing the response. The same
// file_id is reusable by our bot to (re)send the file to any chat
// indefinitely, so "download" for a student means the bot delivering the
// document into their Telegram DM, not a browser download link — see
// materials.controller.ts's downloadMaterial.
model Material {
  id          BigInt          @id @default(autoincrement())
  title       String
  description String
  section     MaterialSection
  subSection  MaterialSubSection?
  fileId      String
  fileName    String
  // "Bepul" when false — guests may download it too, same isFree/guest
  // paywall pattern as Test.isFree. "Pullik" when true — requires role
  // student/admin.
  isPremium   Boolean         @default(false)
  isPublished Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([section])
  @@index([subSection])
}
