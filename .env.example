# --- Database ---
DATABASE_URL="postgresql://tarix:tarix@localhost:5432/tarix?schema=public"
POSTGRES_USER=tarix
POSTGRES_PASSWORD=tarix
POSTGRES_DB=tarix

# --- Telegram Bot ---
# Get this from @BotFather after /newbot
BOT_TOKEN=

# Comma-separated numeric Telegram user IDs that should be treated as teachers/admins.
# Find your own numeric ID via @userinfobot. Role is re-derived on every request,
# so adding/removing an ID here takes effect immediately without a DB migration.
# 999999 matches the frontend's built-in dev "Test Ustoz" identity (see
# frontend/src/telegram/devIdentity.ts) so the teacher role works out of the box
# in local browser testing. Replace/extend with your real Telegram ID for
# production or when testing your own account inside real Telegram.
ADMIN_TELEGRAM_IDS=999999

# Public HTTPS URL of the Mini App frontend (ngrok URL in dev, real domain in prod).
# Used by the bot to build the /start web_app button.
WEBAPP_URL=https://example.ngrok-free.app

# --- Server ---
NODE_ENV=development
PORT=3000

# Dev-only bypass of Telegram initData signature validation, so the app can be
# exercised from a normal browser during development. Structurally cannot be
# enabled in the production Docker image regardless of this file's contents.
ALLOW_DEV_AUTH=true

# Origin allowed by CORS in development (Vite dev server).
FRONTEND_ORIGIN=http://localhost:5173

# --- Production-only (webhook mode) ---
# Public HTTPS base URL Telegram should POST updates to, e.g. https://api.example.com
WEBHOOK_URL=
